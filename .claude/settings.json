{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/session_store_posttooluse.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/pre_compact_alert.py",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/anti_amnesia_capsule.py",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/governance_hooks.py --mode warn",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|NotebookEdit"
      },
      {
        "hooks": [
          {
            "command": ".claude/hooks/recorder_hook.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/inbox_check_hook.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bash scripts/hooks/pre_task_signal.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash|Edit|Write|NotebookEdit"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/session_end_hook.py",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash scripts/hooks/env_schema_validate.sh",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/session_start_audit.py",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/context_compiler.py --budget 2000",
            "timeout": 15,
            "type": "command"
          },
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/cognee_recall.py --on-wake",
            "timeout": 15,
            "type": "command"
          },
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/bd_task_state_injection.py",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/session_uuid_resume.py",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "/home/elliotbot/clawd/venv/bin/python3 scripts/anti_amnesia_capsule.py --read",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "bash scripts/hooks/elliot_session_start_slack_wake.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "bash scripts/ssot_drift_check.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "clear"
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "cd /home/elliotbot/clawd/Agency_OS && PYTHONPATH=/home/elliotbot/clawd/Agency_OS /home/elliotbot/clawd/venv/bin/python3 scripts/governance_router.py",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "bash /home/elliotbot/clawd/Agency_OS/.claude/hooks/stop_relay_hook.sh",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "bash /home/elliotbot/clawd/Agency_OS/scripts/hooks/emit_ready_marker.sh",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "bash .claude/hooks/session_store_stop.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/elliotbot/clawd/Agency_OS/.venv/bin/python3 /home/elliotbot/clawd/Agency_OS/scripts/hooks/elliot_stop_hook.py",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash .claude/hooks/session_store_userpromptsubmit.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "mcpServers": {
    "dataforseo": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/dataforseo-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "DATAFORSEO_LOGIN": "${DATAFORSEO_LOGIN}",
        "DATAFORSEO_PASSWORD": "${DATAFORSEO_PASSWORD}"
      }
    },
    "keiradrive": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/keiradrive-mcp/server.py"
      ],
      "command": "/home/elliotbot/clawd/venv/bin/python3"
    },
    "keiramail": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/gmail-mcp/server.py"
      ],
      "command": "/home/elliotbot/clawd/venv/bin/python3"
    },
    "memory": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/memory-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "SUPABASE_SERVICE_KEY": "${SUPABASE_SERVICE_KEY}",
        "SUPABASE_URL": "${SUPABASE_URL}"
      }
    },
    "prefect": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/prefect-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "PREFECT_API_URL": "${PREFECT_API_URL}"
      }
    },
    "prospeo": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/prospeo-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "PROSPEO_API_KEY": "${PROSPEO_API_KEY}"
      }
    },
    "railway": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/railway-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "RAILWAY_TOKEN": "${Railway_Token}"
      }
    },
    "redis": {
      "args": [
        "-y",
        "@upstash/mcp-server"
      ],
      "command": "npx",
      "env": {
        "UPSTASH_API_KEY": "${UPSTASH_API_KEY}",
        "UPSTASH_EMAIL": "${UPSTASH_EMAIL}"
      }
    },
    "resend": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/resend-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "RESEND_API_KEY": "${RESEND_API_KEY}"
      }
    },
    "salesforge": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/salesforge-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "SALESFORGE_API_KEY": "${SALESFORGE_API_KEY}"
      }
    },
    "supabase": {
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--access-token",
        "${SUPABASE_ACCESS_TOKEN}"
      ],
      "command": "npx",
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}"
      }
    },
    "telnyx": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/telnyx-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "TELNYX_API_KEY": "${TELNYX_API_KEY}"
      }
    },
    "unipile": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/unipile-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "UNIPILE_API_KEY": "${UNIPILE_API_KEY}"
      }
    },
    "vapi": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/vapi-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "VAPI_API_KEY": "${VAPI_API_KEY}"
      }
    },
    "vercel": {
      "args": [
        "/home/elliotbot/clawd/mcp-servers/vercel-mcp/dist/index.js"
      ],
      "command": "node",
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    }
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  }
}
