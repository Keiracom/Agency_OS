[Unit]
Description=Agency OS — Elliot Slack mirror (DUAL_POST half of Step 3 migration)

[Service]
Type=simple
ExecStart=/usr/bin/env python3 /home/elliotbot/clawd/Agency_OS/scripts/elliot_slack_mirror.py
