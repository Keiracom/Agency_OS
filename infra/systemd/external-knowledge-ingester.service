[Unit]
Description=Agency OS — External Knowledge Ingester (KEI-232)
Documentation=https://linear.app/keiracom/issue/KEI-232
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/home/elliotbot/.config/agency-os/.env
WorkingDirectory=/home/elliotbot/clawd/Agency_OS
ExecStart=/home/elliotbot/clawd/Agency_OS/.venv/bin/python3 /home/elliotbot/clawd/Agency_OS/scripts/orchestrator/external_knowledge_ingester.py
Nice=10
StandardOutput=append:/home/elliotbot/clawd/logs/external-knowledge-ingester.log
StandardError=append:/home/elliotbot/clawd/logs/external-knowledge-ingester.log
TimeoutStartSec=3600
MemoryMax=512M
MemoryHigh=384M

[Install]
WantedBy=default.target
